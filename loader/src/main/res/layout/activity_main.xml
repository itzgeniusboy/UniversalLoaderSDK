<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:clipToPadding="false"
        android:layout_above="@+id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Premium Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OneCore Premium"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Virtual Space Engine active"
                android:textColor="@color/ios_text_secondary"
                android:textSize="17sp"
                android:layout_marginBottom="32dp" />

            <!-- Game Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/ios_glass_bg"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BGMI Mobile"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_alignParentRight="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONLINE"
                        android:textColor="@color/ios_success"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 3.2.0 • Global"
                    android:textColor="@color/ios_text_secondary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp" />

                <com.onecore.loader.views.GradientButton
                    android:id="@+id/launchBtn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="LAUNCH CLONE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />
            </LinearLayout>

            <!-- Feature Cards (Skeleton/Status) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINE STATUS"
                android:textColor="@color/ios_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/ios_glass_bg"
                    android:layout_marginRight="8dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clone" android:textColor="@color/ios_text_secondary"/>
                    <TextView android:id="@+id/cloneStat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ready" android:textColor="@color/ios_success" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/ios_glass_bg"
                    android:layout_marginLeft="8dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Engine" android:textColor="@color/ios_text_secondary"/>
                    <TextView android:id="@+id/engineStat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active" android:textColor="@color/ios_success" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- iOS style Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="#E61C1C1E"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <View android:layout_width="24dp" android:layout_height="24dp" android:background="@color/ios_accent"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="@color/ios_accent" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navSettings" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <View android:layout_width="24dp" android:layout_height="24dp" android:background="@color/ios_text_secondary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textColor="@color/ios_text_secondary" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
