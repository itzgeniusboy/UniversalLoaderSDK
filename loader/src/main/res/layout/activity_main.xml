<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Centered Game Icon Space -->
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/ios_glass_bg"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BGMI MOBILE"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/premium_text_p"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VERSION 3.2.0"
            android:textSize="12sp"
            android:textColor="@color/premium_text_s"
            android:layout_marginBottom="40dp"
            android:letterSpacing="0.1" />

        <!-- Centered Glowing Launch Button -->
        <com.onecore.loader.views.GradientButton
            android:id="@+id/launchBtn"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:text="LAUNCH CLONE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:elevation="8dp" />

        <!-- Status Badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="48dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLONE READY"
                style="@style/PremiumBadge"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINE ACTIVE"
                style="@style/PremiumBadge" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIRTUAL ENVIRONMENT SECURE"
            android:textSize="10sp"
            android:textColor="@color/premium_text_s"
            android:layout_marginTop="24dp"
            android:alpha="0.5" />

    </LinearLayout>

</RelativeLayout>
