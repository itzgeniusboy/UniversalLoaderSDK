<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Centered Game Icon Space -->
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/ios_glass_bg"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BGMI MOBILE"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VERSION 3.2.0"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="40dp"
            android:letterSpacing="0.1" />

        <!-- Centered Glowing Launch Button -->
        <com.onecore.loader.views.GradientButton
            android:id="@+id/launchBtn"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:text="LAUNCH CLONE"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="0dp"
            android:elevation="8dp" />

        <!-- Progress HUD -->
        <LinearLayout
            android:id="@+id/progressHud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <ProgressBar
                android:id="@+id/launchProgressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="200dp"
                android:layout_height="6dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="@color/neon_green"
                android:max="100" />

            <TextView
                android:id="@+id/launchStepText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initializing..."
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Final START GAME Button -->
        <com.onecore.loader.views.GradientButton
            android:id="@+id/startGameBtn"
            android:layout_width="240dp"
            android:layout_height="72dp"
            android:text="START GAME"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"
            android:padding="0dp"
            android:visibility="gone"
            android:elevation="12dp" />

        <!-- Status Badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="48dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLONE READY"
                style="@style/PremiumBadge"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/engineBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINE ACTIVE"
                android:textColor="@color/active_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_active"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIRTUAL ENVIRONMENT SECURE"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp"
            android:alpha="0.5" />

    </LinearLayout>

</RelativeLayout>
