rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'theme', 'notificationsEnabled', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.theme in ['light', 'dark', 'system'] &&
             data.notificationsEnabled is bool &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'theme', 'notificationsEnabled']);
    }

    // Task Validation
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'description', 'completed', 'userId', 'createdAt', 'dueDate']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.completed is bool &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             (data.dueDate == null || data.dueDate is timestamp);
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid &&
                    isValidTask(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      // Action: Toggle completion
                      incoming().diff(existing()).affectedKeys().hasOnly(['completed']) ||
                      // Action: Edit task
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'dueDate', 'completed'])
                    );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
